{
  "manifest_version": 3,
  "name": "VDH Replica (Arch Edition)",
  "version": "1.0.0",
  "description": "A clean, privacy-focused video downloader interface built for tinkering.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}